{
  "name": "bannangco-homepage-v2",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "lint": "eslint . --max-warnings=0",
    "typegen": "next typegen",
    "typecheck": "npm run typegen && tsc --noEmit",
    "test": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --test tests/date-only.test.mjs tests/announcement-contract.test.mjs tests/service-catalog.test.mjs tests/cloudflare-deployment.test.mjs tests/privacy-policy.test.mjs tests/production-assurance.test.mjs",
    "build": "next build",
    "check:static": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/check-static-export.mjs",
    "check:cloudflare": "wrangler deploy --dry-run",
    "check:production": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/check-production.mjs",
    "deploy:cloudflare": "wrangler deploy",
    "preview": "serve out"
  },
  "dependencies": {
    "next": "15.5.20",
    "react": "19.2.7",
    "react-dom": "19.2.8"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.5.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.5.20",
    "postcss": "^8.5.20",
    "serve": "14.2.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "wrangler": "4.112.0"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
