{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "bannangco-homepage-v2",
  "compatibility_date": "2026-07-18",
  "assets": {
    "directory": "./out",
    "not_found_handling": "404-page",
    "html_handling": "auto-trailing-slash"
  },
  "routes": [
    {
      "pattern": "bannangco.com",
      "custom_domain": true
    }
  ],
  "workers_dev": false,
  "preview_urls": false
}
